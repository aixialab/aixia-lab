---
export interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
---

{
  headings.length > 0 && (
    <nav class="toc hidden lg:block sticky top-20">
      <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">
        目次
      </h4>
      <ul class="space-y-1.5 border-l border-[var(--color-border)] pl-3">
        {headings.map((heading) => (
          <li style={`padding-left: ${(heading.depth - 2) * 0.75}rem;`}>
            <a href={`#${heading.slug}`} class="toc-link block">
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
