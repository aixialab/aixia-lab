---
import ThemeToggle from './ThemeToggle.astro';
import { SITE } from '../constants/site';

const navigation = [
  { href: '/', label: 'ホーム' },
  { href: '/categories/', label: 'カテゴリ' },
  { href: '/tags/', label: 'タグ' },
  { href: '/about/', label: 'About' },
];
---

<header class="sticky top-0 z-50 bg-[var(--color-bg)]/80 backdrop-blur-md border-b border-[var(--color-border)]">
  <nav class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="font-bold text-lg tracking-tight shrink-0">
      {SITE.name}
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      {navigation.map((item) => (
        <a
          href={item.href}
          class="text-sm px-3 py-1.5 rounded-md text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-alt)] transition-colors"
        >
          {item.label}
        </a>
      ))}
      <ThemeToggle />
    </div>
  </nav>
</header>
