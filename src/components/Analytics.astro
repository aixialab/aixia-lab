---
const defaultGaId = 'G-YH9JP6L1PW';
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || defaultGaId;
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
---

{gscVerification && <meta name="google-site-verification" content={gscVerification} />}

{
  gaId && (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    </>
  )
}
