---
import Layout from './Layout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { formatDate, formatDateISO } from '../utils/helpers';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
  relatedPosts: CollectionEntry<'blog'>[];
  headings: { depth: number; slug: string; text: string }[];
}

const { post, relatedPosts, headings } = Astro.props;
const { title, description, pubDate, updatedDate, category, tags, heroImage } = post.data;
---

<Layout
  title={title}
  description={description}
  ogImage={heroImage || undefined}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  tags={tags}
>
  <div class="max-w-5xl mx-auto px-4 py-8 lg:py-12">
    <div class="lg:grid lg:grid-cols-[1fr_200px] lg:gap-10">
      <!-- Main content -->
      <article class="max-w-none">
        <header class="mb-8">
          <div class="flex items-center gap-2 text-sm mb-3">
            <a
              href={`/categories/${encodeURIComponent(category)}/`}
              class="px-2 py-0.5 rounded-full bg-[var(--color-bg-alt)] text-[var(--color-primary)] border border-[var(--color-border)] no-underline"
            >
              {category}
            </a>
            {tags.map((tag) => (
              <a href={`/tags/${encodeURIComponent(tag)}/`} class="text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">
                #{tag}
              </a>
            ))}
          </div>

          <h1 class="text-2xl sm:text-3xl font-bold leading-tight mb-4">
            {title}
          </h1>

          <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-[var(--color-text-muted)]">
            <time datetime={formatDateISO(pubDate)}>
              公開: {formatDate(pubDate)}
            </time>
            {updatedDate && (
              <time datetime={formatDateISO(updatedDate)}>
                更新: {formatDate(updatedDate)}
              </time>
            )}
          </div>
        </header>

        {heroImage && (
          <img
            src={heroImage}
            alt={`${title}のアイキャッチ画像`}
            loading="lazy"
            class="w-full rounded-xl border border-[var(--color-border)] mb-8"
          />
        )}

        <div class="prose">
          <slot />
        </div>

        <!-- Related articles -->
        {relatedPosts.length > 0 && (
          <section class="mt-12 pt-8 border-t border-[var(--color-border)]">
            <h3 class="text-lg font-bold mb-4">関連記事</h3>
            <div class="grid gap-4 sm:grid-cols-2">
              {relatedPosts.map((rp) => <ArticleCard post={rp} />)}
            </div>
          </section>
        )}
      </article>

      <!-- Sidebar TOC -->
      <aside>
        <TableOfContents headings={headings} />
      </aside>
    </div>
  </div>
</Layout>
